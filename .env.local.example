# =============================================================================
# SuperCompute — Decentralized AI Inference Platform
# Environment Variable Template (copy to .env.local and fill in values)
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
SC_DB_PATH=./data/supercompute.db          # Path to SQLite database file
SC_DB_URL=postgresql://user:pass@localhost:5432/supercompute  # Postgres connection string (alternative to SQLite)

# ── Server / Networking ───────────────────────────────────────────────────────
SC_WS_PORT=8080                            # WebSocket server port for real-time inference streams
SC_HTTP_PORT=3001                          # HTTP API server port
SC_HOST=0.0.0.0                            # Bind address for all server listeners
SC_NODE_ID=node-1                          # Unique identifier for this SuperCompute node

# ── Keeper (Scheduled Jobs) ───────────────────────────────────────────────────
SC_KEEPER_HOUR=3                           # Hour (0-23) at which the daily keeper/maintenance job runs (UTC)
SC_KEEPER_INTERVAL_SEC=3600                # Polling interval (seconds) for periodic keeper tasks

# ── ComfyUI (AI Inference Backend) ────────────────────────────────────────────
SC_COMFY_URL=http://localhost:8188         # ComfyUI API endpoint for workflow execution

# ── Solana (Blockchain) ───────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com  # Solana JSON-RPC endpoint (use devnet for testing)
SOLANA_RPC_WS_URL=wss://api.mainnet-beta.solana.com # Solana WebSocket endpoint for real-time events
SOLANA_NETWORK=mainnet-beta                # Solana cluster: mainnet-beta | devnet | testnet | localnet

# ── Token (SUPER) ─────────────────────────────────────────────────────────────
TOKEN_MINT=So11111111111111111111111111111111111111112  # SPL token mint address for the SUPER token
SUPER_TOKEN_DECIMALS=9                    # Decimal places for the SUPER token

# ── Wallet Keys (Administrative) ──────────────────────────────────────────────
TREASURY_WALLET_KEY=                      # Solana private key (Base58) for the protocol treasury wallet
DEPOSIT_WALLET_KEY=                       # Solana private key (Base58) for receiving user deposits

# ── Privy (Authentication) ────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=                 # Public-facing Privy application ID (safe in client)
PRIVY_APP_SECRET=                          # Privy application secret — KEEP PRIVATE, never commit

# ── Internal Secrets ──────────────────────────────────────────────────────────
INTERNAL_API_SECRET=                       # Shared secret for authenticating internal service-to-service API calls
ADMIN_SECRET=                              # Secret token for admin-level operations and protected endpoints

# ── Logging / Observability ───────────────────────────────────────────────────
SC_LOG_LEVEL=info                          # Logging level: debug | info | warn | error
SC_LOG_FORMAT=json                         # Log output format: json | text

# ── Rate Limiting ─────────────────────────────────────────────────────────────
SC_RATE_LIMIT_RPM=60                       # Max requests per minute per IP (rate limiting)
SC_RATE_LIMIT_BURST=20                     # Max burst size before rate limiter activates
